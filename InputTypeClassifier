{"nbformat":4,"nbformat_minor":0,"metadata":{"colab":{"provenance":[],"authorship_tag":"ABX9TyP0glbRVpe4ecNK9Py7rJ8G"},"kernelspec":{"name":"python3","display_name":"Python 3"},"language_info":{"name":"python"}},"cells":[{"cell_type":"code","source":["import os\n","import numpy as np\n","import joblib\n","from sklearn.tree import DecisionTreeClassifier\n","from sklearn.model_selection import train_test_split\n","from sklearn.metrics import accuracy_score, f1_score\n"],"metadata":{"id":"Tr9fEUumcglw","executionInfo":{"status":"ok","timestamp":1766240116456,"user_tz":-300,"elapsed":1716,"user":{"displayName":"Firebase TTWF","userId":"03962077500592247815"}}},"execution_count":2,"outputs":[]},{"cell_type":"code","source":["from google.colab import drive\n","drive.mount(\"/content/drive\")\n","\n","IMAGE_ZIP_PATH = \"/content/drive/MyDrive/cyber_fusion_models/org.zip\"\n","TEXT_ZIP_PATH  = \"/content/drive/MyDrive/cyber_fusion_models/MalwareTextDB-1.0 (1).zip\"\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"sPdpGYB-4PZb","executionInfo":{"status":"ok","timestamp":1766240142186,"user_tz":-300,"elapsed":24621,"user":{"displayName":"Firebase TTWF","userId":"03962077500592247815"}},"outputId":"782eae5e-2946-41ee-d6e0-87957688740c"},"execution_count":3,"outputs":[{"output_type":"stream","name":"stdout","text":["Mounted at /content/drive\n"]}]},{"cell_type":"markdown","source":["**Feature Extractor**"],"metadata":{"id":"iG7j-dVleUiW"}},{"cell_type":"code","source":["import math\n","import numpy as np\n","import zipfile\n","from collections import Counter\n","\n","def shannon_entropy(data: bytes):\n","    if not data:\n","        return 0.0\n","    counts = Counter(data)\n","    probs = [c / len(data) for c in counts.values()]\n","    return -sum(p * math.log2(p) for p in probs)\n","\n","def extract_structural_features(source):\n","    # -------------------------------------------------\n","    # Read raw bytes from:\n","    #  (a) ZIP member  -> (zip_path, inner_path)\n","    #  (b) normal file -> \"path/to/file\"\n","    # -------------------------------------------------\n","    if isinstance(source, tuple):\n","        zip_path, inner_path = source\n","        with zipfile.ZipFile(zip_path, \"r\") as zf:\n","            raw = zf.read(inner_path)\n","    else:\n","        with open(source, \"rb\") as f:\n","            raw = f.read()\n","\n","    size = len(raw)\n","    entropy = shannon_entropy(raw)\n","\n","    # Byte-level statistics\n","    ascii_ratio = sum(32 <= b <= 126 for b in raw) / max(1, size)\n","    byte_var = np.var(np.frombuffer(raw, dtype=np.uint8)) if size > 0 else 0.0\n","\n","    # Signature checks\n","    is_png = int(raw.startswith(b\"\\x89PNG\"))\n","\n","    # Decode for text-like features (works for both tabular and text)\n","    text = raw.decode(errors=\"ignore\")\n","\n","    line_count = text.count(\"\\n\")\n","    comma_count = text.count(\",\")\n","    tab_count = text.count(\"\\t\")\n","    semicolon_count = text.count(\";\")\n","\n","    tokens = text.split()\n","    token_count = len(tokens)\n","\n","    # Stronger tabular-vs-text separators\n","    # - Tabular often has many digits and consistent line lengths\n","    # - JSON/Markdown text tends to have more punctuation/braces\n","    digits = sum(ch.isdigit() for ch in text)\n","    letters = sum(ch.isalpha() for ch in text)\n","    punct = sum(ch in \"{}[]():\\\"'<>/\" for ch in text)\n","\n","    digit_ratio = digits / max(1, len(text))\n","    letter_ratio = letters / max(1, len(text))\n","    punct_ratio = punct / max(1, len(text))\n","\n","    # Line length stats\n","    lines = text.splitlines()\n","    if len(lines) > 0:\n","        lengths = [len(ln) for ln in lines[:2000]]  # cap for safety\n","        avg_line_len = float(np.mean(lengths))\n","        max_line_len = float(np.max(lengths))\n","    else:\n","        avg_line_len = 0.0\n","        max_line_len = 0.0\n","\n","    # Return a compact feature vector\n","    return [\n","        size,\n","        entropy,\n","        ascii_ratio,\n","        byte_var,\n","        line_count,\n","        comma_count,\n","        token_count,\n","        is_png,\n","        tab_count,\n","        semicolon_count,\n","        digit_ratio,\n","        letter_ratio,\n","        punct_ratio,\n","        avg_line_len,\n","        max_line_len\n","    ]\n"],"metadata":{"id":"3B1uT63ZcmFU","executionInfo":{"status":"ok","timestamp":1766240157321,"user_tz":-300,"elapsed":4,"user":{"displayName":"Firebase TTWF","userId":"03962077500592247815"}}},"execution_count":4,"outputs":[]},{"cell_type":"markdown","source":["**Image Sample**"],"metadata":{"id":"9SJlWBVSdavb"}},{"cell_type":"code","source":["import zipfile, random\n","\n","IMAGE_ZIP_PATH = \"/content/drive/MyDrive/cyber_fusion_models/org.zip\"\n","\n","image_files = []\n","with zipfile.ZipFile(IMAGE_ZIP_PATH, \"r\") as zf:\n","    pngs = [f for f in zf.namelist() if f.lower().endswith(\".png\")]\n","    sampled = random.sample(pngs, min(300, len(pngs)))\n","    for name in sampled:\n","        image_files.append((IMAGE_ZIP_PATH, name))  # (zip, inner_path)\n"],"metadata":{"id":"N6nrn5MvdW_z","executionInfo":{"status":"ok","timestamp":1766240163141,"user_tz":-300,"elapsed":1876,"user":{"displayName":"Firebase TTWF","userId":"03962077500592247815"}}},"execution_count":5,"outputs":[]},{"cell_type":"markdown","source":["**Remote CTI Samples**"],"metadata":{"id":"yZLTuVTG41jT"}},{"cell_type":"code","source":["# =========================================\n","# STEP 1: Fetch remote text dataset (MITRE CTI)\n","# =========================================\n","\n","import os\n","\n","if not os.path.exists(\"cti\"):\n","    !git clone https://github.com/mitre/cti.git\n","else:\n","    print(\"CTI repository already exists\")\n"],"metadata":{"colab":{"base_uri":"https://localhost:8080/"},"id":"bDK9AigLyTNq","executionInfo":{"status":"ok","timestamp":1766240203395,"user_tz":-300,"elapsed":38545,"user":{"dis